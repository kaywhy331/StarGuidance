# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=StarGuidance
APP_ENV=development
ENABLE_VISUAL_PREVIEW=false

# Sensitive-field encryption (32-byte base64 key; generate locally, never commit it)
DATA_ENCRYPTION_KEY=

# Supabase Auth, Postgres, and Storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Profile engine
PROFILE_ENGINE_URL=http://127.0.0.1:8000
PROFILE_ENGINE_SHARED_SECRET=
ENABLE_WESTERN_ASTROLOGY=false
ENABLE_BAZI=false

# Provider-agnostic AI adapter (fallback is used when disabled or unconfigured)
AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=

# Stripe test mode (local adapter is used when disabled)
PAYMENTS_PROVIDER=local
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PROFILE_REPORT_PRICE_ID=

# Privacy-safe observability; do not send birth data or question text
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
