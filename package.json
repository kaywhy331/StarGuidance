{
  "name": "starguidance",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "corepack pnpm --recursive --if-present build",
    "dev": "corepack pnpm --filter @starguidance/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "corepack pnpm --recursive --if-present typecheck",
    "test": "corepack pnpm --recursive --if-present test",
    "test:e2e": "corepack pnpm --filter @starguidance/web test:e2e",
    "db:check": "corepack pnpm --filter @starguidance/database db:check",
    "db:seed": "tsx packages/database/src/seed.ts"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.12",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "prettier": "3.9.6",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
